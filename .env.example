# ==================== 环境变量示例 ====================
# 复制为 .env 并按需修改。框架通过 python-dotenv 加载，或业务项目自行处理。

# 当前环境: prod / test / dev
ENV=prod

# 项目根目录（通常不需要手动设置，run_test.py 会自动注入）
# PROJECT_ROOT=

# 日志
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_RETENTION_DAYS=15

# 飞书通知
FEISHU_WEBHOOK_URL=
FEISHU_NOTIFY_ENABLED=true

# 报告访问地址（用于飞书卡片中的链接）
REPORT_BASE_URL=http://localhost:8000

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false

# 数据库跳板机（使用 autotest.db 时需要）
JUMP_HOST_IP=
JUMP_HOST_PORT=2222
JUMP_HOST_USER=
JUMP_HOST_PASSWORD=
DB_DEFAULT_USER=readonly
DB_DEFAULT_PASSWORD=
